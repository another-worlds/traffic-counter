# --- Local dev (docker-compose) ---
# Everything is wired in docker-compose.yml. Override here if needed.

# CORS_ORIGINS controls which browser origins may call the API. Defaults
# to "*" (any origin, credentials disabled) so any host the operator
# deploys Streamlit on works out of the box. Override with a comma-
# separated allowlist when you need cookie-bearing requests.
# Example: CORS_ORIGINS=http://localhost:8501,http://localhost:8000

# PUBLIC_API_URL is the API URL reachable from the *user's browser*. Leave
# unset on single-host deployments — the React iframe will derive the
# API host from window.location automatically (port 8000). Set this only
# when the API is reached from a different host than Streamlit (split DNS,
# custom ingress, HTTPS termination).
# Example: PUBLIC_API_URL=https://api.example.com

# --- Production (GCP) ---
# Set these when deploying with infra/deploy.sh

GCP_PROJECT=your-gcp-project
GCP_REGION=europe-west4
GCS_BUCKET=traffic-counter-your-suffix
CLOUDSQL_INSTANCE=traffic-counter-pg
DB_PASSWORD=change-me

# Cloud Run service names
API_SERVICE=traffic-counter-api
FRONTEND_SERVICE=traffic-counter-frontend
WORKER_JOB=traffic-counter-worker

# Artifact registry
AR_REPO=traffic-counter
