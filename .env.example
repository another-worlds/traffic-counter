# --- Local dev (docker-compose) ---
# Everything is wired in docker-compose.yml. Override here if needed.

# --- Production (GCP) ---
# Set these when deploying with infra/deploy.sh

GCP_PROJECT=your-gcp-project
GCP_REGION=europe-west4
GCS_BUCKET=traffic-counter-your-suffix
CLOUDSQL_INSTANCE=traffic-counter-pg
DB_PASSWORD=change-me

# Cloud Run service names
API_SERVICE=traffic-counter-api
FRONTEND_SERVICE=traffic-counter-frontend
WORKER_JOB=traffic-counter-worker

# Artifact registry
AR_REPO=traffic-counter
